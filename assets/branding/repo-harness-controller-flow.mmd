flowchart LR
  classDef chatgpt fill:#11284B,color:#F6FAFF,stroke:#11284B,stroke-width:2px
  classDef controller fill:#1A4A55,color:#F6FFFE,stroke:#1A4A55,stroke-width:2px
  classDef repo fill:#6B4A1E,color:#FFF8ED,stroke:#6B4A1E,stroke-width:2px
  classDef agent fill:#50317B,color:#FCF8FF,stroke:#50317B,stroke-width:2px
  classDef support fill:#EFF5FF,color:#17365C,stroke:#AFC4E5,stroke-width:1.5px

  C["ChatGPT<br/>Analyze request<br/>Choose execution mode<br/>Review results"]:::chatgpt
  O["repo-harness Controller<br/>MCP bridge + local UI<br/>Issue / Task / Run<br/>Direct Edit + checks"]:::controller
  R["Repository truth<br/>plans/ tasks/ .ai/context/ .ai/harness/<br/>contracts, reviews, handoffs, traces"]:::repo
  A["Scoped agents<br/>Codex / Claude / GitHub Copilot<br/>worktree runs + compile/test/fix loops"]:::agent
  D["Direct Edit fast path<br/>small known changes can write back directly"]:::support
  H["Human review gate<br/>checks, diffs, evidence, explicit acceptance"]:::support

  C --> O --> R --> A
  A -. diff, logs, evidence .-> O
  O -. default path .-> D
  D --> R
  R --> H --> O
